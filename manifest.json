{
  "manifest_version": 3,
  "name": "ClickDesign1.2",
  "version": "1.2.0",
  "description": "プロ級のクオリティでサムネイルを生成するツール。",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://queue.fal.run/*",
    "https://fal.run/*",
    "https://api.fal.ai/*",
    "https://api.fal.run/*",
    "https://rest.alpha.fal.ai/*",
    "https://v3b.fal.media/*",
    "https://fal.media/*",
    "https://api.apiyi.com/*"
  ],
  "icons": {
    "16": "icons/favicon.png",
    "32": "icons/favicon.png",
    "48": "icons/favicon.png",
    "128": "icons/favicon.png"
  },
  "action": {
    "default_title": "ClickDesign1.2",
    "default_icon": {
      "16": "icons/favicon.png",
      "32": "icons/favicon.png",
      "48": "icons/favicon.png",
      "128": "icons/favicon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
