# ============================================================
# ClickDesign 環境変数 (Vercel側で設定)
# ============================================================
# 本ファイルはサンプルです。実際の値はVercelダッシュボードの
# Settings → Environment Variables に設定してください。
# ============================================================

# Neon Postgres (Marketplace連携時に自動設定される)
DATABASE_URL=postgres://...

# JWT署名用の秘密鍵 (32文字以上の英数字をランダム生成)
# 例: openssl rand -hex 32
JWT_SECRET=

# 管理画面 (/admin.html) のログインパスワード
# 強固なものを設定してください
ADMIN_PASSWORD=
